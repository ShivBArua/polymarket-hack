# Polymarket Strategy Lab — Environment Variables
# Copy this file to .env.local and fill in values as needed.

# Reserved for future Polymarket CLOB API credentials (order placement)
# POLYMARKET_API_KEY=
# POLYMARKET_SECRET=
# POLYMARKET_PASSPHRASE=

# Reserved for wallet integration (trading features)
# POLYMARKET_PRIVATE_KEY=
# POLYMARKET_ADDRESS=

# Optional: override default API base URLs
# NEXT_PUBLIC_GAMMA_BASE=https://gamma-api.polymarket.com
# NEXT_PUBLIC_CLOB_BASE=https://clob.polymarket.com
